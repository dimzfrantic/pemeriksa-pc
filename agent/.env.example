# Konfigurasi PC Monitor Agent (CONTOH — sesuaikan nilainya)
# AGENT_NAME : sama persis dengan nama PC di aplikasi web (mis. contoh1)
# SERVER_URL : alamat server aplikasi
# AGENT_TOKEN: samakan dengan AGENT_TOKEN di .env server
SERVER_URL=http://10.0.0.10:5080
AGENT_NAME=contoh1
AGENT_TOKEN=ganti-dengan-token-yang-sama-dengan-server
INTERVAL_SECONDS=60
START_WITH_WINDOWS=true
