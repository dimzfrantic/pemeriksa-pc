# Salin menjadi .env dan sesuaikan. JANGAN commit .env yang sudah terisi.
SECRET_KEY=ganti-dengan-string-acak-panjang
SQLALCHEMY_DATABASE_PATH=instance/pcmonitor.db

# === Telegram (bot khusus pemeriksaan PC, BUKAN token bot lain) ===
TELEGRAM_BOT_TOKEN=isi-token-bot-dari-botfather
TELEGRAM_ALLOWED_CHAT_IDS=-100xxxxxxxxxx
# Thread/topic ID forum tempat bot merespon (kosong = semua topik)
TELEGRAM_ALLOWED_THREAD_IDS=

# === Token agen Windows (samakan dengan AGENT_TOKEN di tiap agen) ===
AGENT_TOKEN=ganti-dengan-token-acak-aman
# Ambang detik untuk menganggap PC offline (default 180 = 3 menit)
AGENT_OFFLINE_SECONDS=180

# === Mode AI fallback (opsional; biarkan kosong untuk menonaktifkan) ===
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# === Akun admin (cadangan, bila auth web diaktifkan) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
